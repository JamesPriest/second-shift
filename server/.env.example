# Absolute path to your Factorio script-output directory.
#
# Windows example: C:\Users\YourName\AppData\Roaming\Factorio\script-output
#   (tip: paste %APPDATA%\Factorio\script-output into Explorer to find it)
#
# Linux example:   /home/yourname/.factorio/script-output
#
# Mac example:     /Users/yourname/Library/Application Support/factorio/script-output
FACTORIO_SCRIPT_OUTPUT=/path/to/factorio/script-output

# Optional: absolute path to your Factorio DATA directory (NOT script-output).
# When set, item icons are served from the game files.
#
# Windows example: C:\Program Files (x86)\Steam\steamapps\common\Factorio\data
# Linux   example: /home/yourname/.factorio/data  (or Steam: ~/.steam/steam/steamapps/common/Factorio/data)
# Mac     example: /Applications/factorio.app/Contents/data
#
# FACTORIO_DATA_PATH=

# Port the dashboard server listens on
PORT=3000

# How many historical snapshots to keep in memory for the time-series chart.
# Each snapshot is ~5 seconds apart, so 60 = ~5 minutes of history.
HISTORY_LENGTH=60
